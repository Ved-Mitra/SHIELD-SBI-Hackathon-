# Server Binding Address
GATE1_ADDR=:8081

# JWT Settings
GATE1_JWT_PRIVATE_KEY_PATH=certs/gate1/private.pem
GATE1_JWT_TTL=2m
GATE1_JWT_ISSUER=shield-gate1
GATE1_JWT_AUDIENCE=shield-gate2

# Mobile App Identifiers
GATE1_ANDROID_PACKAGE_NAME=
GATE1_IOS_APP_ID=

# Play Integrity API Service Account (leave empty for ADC)
GATE1_SERVICE_ACCOUNT_PATH=

# Redis Store for Nonces
GATE1_NONCE_STORE_ADDR=localhost:6379
GATE1_NONCE_TTL=5m

# Development Only
# Set to false in production to enforce real Play Integrity / App Attest verification
GATE1_MOCK_ATTESTATION=true
